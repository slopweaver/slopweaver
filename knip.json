{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/**/*.entry.ts", "hooks/pretooluse-admit.ts", "eval/*.ts", "src/**/*.test.ts"],
  "ignoreDependencies": ["oxlint"],
  "ignoreExportsUsedInFile": true,
  "project": ["src/**/*.ts", "hooks/**/*.ts", "eval/**/*.ts"],
  "rules": { "duplicates": "off" }
}
