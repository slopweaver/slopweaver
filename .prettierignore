# Prettier only formats the doc formats Biome leaves alone (.md, .yaml, .yml, ...).
# Biome owns all JS/TS/JSON/JSONC/CSS — keep Prettier off them so the two never fight.
**/*.js
**/*.jsx
**/*.ts
**/*.tsx
**/*.mjs
**/*.cjs
**/*.mts
**/*.cts
**/*.json
**/*.jsonc
**/*.css

# Binary / media — not text Prettier should touch.
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.svg
**/*.pdf
**/*.mp4
**/*.woff
**/*.woff2

# Auto-generated / vendored / build output — not ours to format.
**/node_modules/
**/dist/
**/build/
**/generated/
**/out/
**/target/
**/.turbo/
**/.cache/
**/coverage/
**/test-results/
**/*.tsbuildinfo

# Lockfiles — auto-generated; formatting corrupts them.
yarn.lock
package-lock.json
pnpm-lock.yaml
.yarn/

# Frozen eval corpus + recorded baseline — reformatting would break determinism.
eval/fixtures/
eval/baseline.recall.json
