# Deps + build output — installed/built, never committed
node_modules/
dist/
**/*.tsbuildinfo

# Yarn 4 (Berry) — commit yarn.lock + .yarnrc.yml only; the version is resolved by Corepack/proto
.yarn/*
!.yarn/patches
.pnp.*

# Local world-model artifacts — a defensive net for a repo-relative $SLOPWEAVER_HOME. Anchored to the
# repo ROOT (leading `/`) so these NEVER match in-repo source dirs like `src/corpus/`. The real state
# lives under $SLOPWEAVER_HOME (outside the repo) and is never committed regardless.
/.cache/
/corpus/

# Claude Code plugin data
.claude/plugins/

.DS_Store
