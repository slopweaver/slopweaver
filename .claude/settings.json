{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git remote:*)",
      "Bash(git worktree:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm cli:*)",
      "Bash(pnpm compile:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm format:check:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm test:unit:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo view:*)",
      "Bash(gh api repos/slopweaver/*/issues/*)",
      "Bash(gh run watch:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(codex-agent:*)",
      "Bash(ls:*)",
      "Bash(find . -*)",
      "Bash(grep -*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(mkdir -p:*)",
      "Bash(npm view:*)",
      "Bash(node --version:*)",
      "Bash(pnpm --version:*)"
    ]
  },
  "enabledPlugins": {
    "cartographer@cartographer-marketplace": true
  }
}
