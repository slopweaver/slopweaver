{
  "name": "@slopweaver/db",
  "version": "0.0.0",
  "private": false,
  "description": "SlopWeaver SQLite package. Drizzle schema, generated migrations, and createDb helper.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "compile": "tsc --noEmit",
    "drizzle-kit": "drizzle-kit",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "12.2.0",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
