{
  "name": "@slopweaver/mcp-server",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic MCP server for SlopWeaver. Tool registry, builtin tools, stdio transport.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@slopweaver/contracts": "workspace:*",
    "@slopweaver/db": "workspace:*",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
