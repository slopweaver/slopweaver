{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.jsonc",
      "**/*.md",
      "!**/__recordings__/**",
      "!**/.turbo/**",
      "!**/build/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/generated/**",
      "!**/node_modules/**",
      "!**/out/**",
      "!**/eslint.config.js"
    ]
  },
  "assist": {
    "enabled": true,
    "actions": {
      "recommended": true,
      "source": {
        "organizeImports": "on",
        "useSortedKeys": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "json": {
    "parser": {
      "allowComments": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noConstAssign": "error",
        "noUnusedImports": "error",
        "noVoidTypeReturn": "warn",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error",
        "useIsNan": "error"
      },
      "nursery": {
        "noLeakedRender": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noDynamicNamespaceImportAccess": "warn"
      },
      "suspicious": {
        "noDebugger": "error",
        "noEvolvingTypes": "error",
        "noImplicitAnyLet": "error",
        "noSuspiciousSemicolonInJsx": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  }
}
