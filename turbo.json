{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["tsconfig.base.json", ".nvmrc"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"],
      "cache": true
    },
    "compile": {
      "dependsOn": ["^compile"],
      "outputs": ["dist/**", "*.tsbuildinfo"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:unit": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
