{
  "name": "slopweaver",
  "version": "0.1.0",
  "description": "Build a local-first, zero-key org world model from your GitHub history — ingest it, tier it, and ask questions of it, all on your machine.",
  "type": "module",
  "packageManager": "yarn@4.17.1",
  "bin": "./dist/cli/index.js",
  "scripts": {
    "slopweaver": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "hygiene": "bash scripts/check-hygiene.sh",
    "check:pr-format": "tsx src/prformat/check.ts",
    "eval": "promptfoo eval -c eval/promptfooconfig.yaml",
    "eval:view": "promptfoo view -y"
  },
  "devDependencies": {
    "@types/node": "^24.10",
    "promptfoo": "^0.121.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.11"
  },
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@xenova/transformers": "^2.17.2"
  },
  "resolutions": {
    "sharp": "portal:./stubs/sharp"
  }
}
