{
  "name": "slopweaver-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "SlopWeaver workspace root. The shipped binary is published as `slopweaver` from apps/mcp-local/.",
  "license": "MIT",
  "homepage": "https://slopweaver.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slopweaver/slopweaver.git"
  },
  "author": "lachiejames",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "cli": "tsx packages/cli-tools/src/cli.ts",
    "compile": "turbo run compile",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "knip": "knip",
    "lint": "biome lint . && eslint .",
    "prepare": "lefthook install || echo 'lefthook install skipped (not a git repository)'",
    "test": "turbo run test",
    "validate": "pnpm format:check && pnpm lint && pnpm compile && pnpm test && pnpm knip"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "22.19.17",
    "eslint": "10.3.0",
    "eslint-plugin-boundaries": "6.0.2",
    "knip": "6.7.0",
    "lefthook": "2.1.6",
    "tsx": "4.21.0",
    "turbo": "2.9.7",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "nock": "13.5.6"
    },
    "patchedDependencies": {
      "@pollyjs/adapter-node-http@6.0.6": "patches/@pollyjs__adapter-node-http@6.0.6.patch"
    }
  }
}
