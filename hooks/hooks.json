{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [{ "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/pretooluse-admit.sh\"", "type": "command" }],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/plugin-install-deps.sh\"", "type": "command" },
          { "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/slopweaver\" init >/dev/null 2>&1 || true", "type": "command" }
        ]
      }
    ]
  }
}
