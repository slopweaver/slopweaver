{
  "name": "@slopweaver/mcp-local",
  "version": "0.0.0",
  "private": false,
  "description": "SlopWeaver local MCP server. Publishable npm binary that wires @slopweaver/db + @slopweaver/mcp-server and exposes the `slopweaver` command over stdio.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "slopweaver": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "compile": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "8.4.2",
    "@slopweaver/db": "workspace:*",
    "@slopweaver/env": "workspace:*",
    "@slopweaver/integrations-github": "workspace:*",
    "@slopweaver/integrations-slack": "workspace:*",
    "@slopweaver/mcp-server": "workspace:*",
    "cac": "7.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@slopweaver/contracts": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
