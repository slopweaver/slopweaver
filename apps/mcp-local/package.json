{
  "name": "@slopweaver/mcp-local",
  "version": "0.0.0",
  "private": false,
  "description": "SlopWeaver local MCP server. Publishable npm binary that wires @slopweaver/db + @slopweaver/mcp-server and exposes the `slopweaver` command over stdio.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "slopweaver": "./dist/cli.js"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "better-sqlite3": "12.2.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@slopweaver/contracts": "workspace:*",
    "@slopweaver/db": "workspace:*",
    "@slopweaver/mcp-server": "workspace:*",
    "@types/better-sqlite3": "7.6.13",
    "esbuild": "0.27.7",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
